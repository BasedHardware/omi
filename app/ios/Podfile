# Uncomment this line to define a global platform for your project
platform :ios, '17.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug-prod' => :debug,
  'Profile-prod' => :release,
  'Release-prod' => :release,
  'Debug-dev' => :debug,
  'Profile-dev' => :release,
  'Release-dev' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# NOTE: Do NOT force SwiftProtobuf to a dynamic framework and strip it from the
# Runner embed step. That produced a Runner binary loading
# @rpath/SwiftProtobuf.framework that was never embedded/signed into the app
# bundle -> dyld "Library not loaded" crash at launch on device (stuck on
# splash, no logs). The static-linkage duplicate-class objc warning from
# MWDATCore is harmless; keep static linkage.

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  pod 'TwilioVoice', '~> 6.13'
end

def patch_firebase_crashlytics_status_bar_orientation(installer)
  notification_manager = File.join(
    installer.sandbox.root.to_s,
    'FirebaseCrashlytics/Crashlytics/Crashlytics/Controllers/FIRCLSNotificationManager.m'
  )
  return unless File.exist?(notification_manager)

  File.chmod(0o644, notification_manager) rescue nil
  source = File.read(notification_manager)
  return if source.include?('FIRCLSSafeStatusBarOrientation')

  helper = <<~'OBJC'
    #if TARGET_OS_IOS && (!CLS_TARGET_OS_VISION)
    static UIInterfaceOrientation FIRCLSSafeStatusBarOrientation(void) {
      if (@available(iOS 13.0, *)) {
        UIApplication *application = (UIApplication *)FIRCLSApplicationSharedInstance();
        UIWindowScene *fallbackWindowScene = nil;
        for (UIScene *scene in application.connectedScenes) {
          if (![scene isKindOfClass:[UIWindowScene class]]) {
            continue;
          }
          UIWindowScene *windowScene = (UIWindowScene *)scene;
          if (scene.activationState == UISceneActivationStateForegroundActive ||
              scene.activationState == UISceneActivationStateForegroundInactive) {
            return windowScene.interfaceOrientation;
          }
          if (fallbackWindowScene == nil) {
            fallbackWindowScene = windowScene;
          }
        }
        return fallbackWindowScene == nil ? UIInterfaceOrientationUnknown
                                          : fallbackWindowScene.interfaceOrientation;
      }
      return UIInterfaceOrientationUnknown;
    }
    #endif  // TARGET_OS_IOS && (!CLS_TARGET_OS_VISION)

  OBJC

  source.sub!("#endif\n\n@implementation FIRCLSNotificationManager", "#endif\n\n#{helper}@implementation FIRCLSNotificationManager")
  source.gsub!(
    "UIInterfaceOrientation statusBarOrientation =\n      [FIRCLSApplicationSharedInstance() statusBarOrientation];",
    'UIInterfaceOrientation statusBarOrientation = FIRCLSSafeStatusBarOrientation();'
  )
  File.write(notification_manager, source)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings.delete 'IPHONEOS_DEPLOYMENT_TARGET'
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',

        # dart: PermissionGroup.notification
        'PERMISSION_NOTIFICATIONS=1',

        # dart: PermissionGroup.bluetooth
        'PERMISSION_BLUETOOTH=1',

        # dart: PermissionGroup.microphone
        'PERMISSION_MICROPHONE=1',
        
        ## The 'PERMISSION_LOCATION' macro enables the `locationWhenInUse` and `locationAlways` permission. If
        ## the application only requires `locationWhenInUse`, only specify the `PERMISSION_LOCATION_WHENINUSE`
        ## macro.
        ##
        ## dart: [PermissionGroup.location, PermissionGroup.locationAlways, PermissionGroup.locationWhenInUse]
        'PERMISSION_LOCATION=1',
        'PERMISSION_LOCATION_WHENINUSE=1',
        'PERMISSION_LOCATION_ALWAYS=1',

        ## dart: PermissionGroup.calendarFullAccess
        'PERMISSION_EVENTS_FULL_ACCESS=1',

        ## dart: PermissionGroup.calendar
        'PERMISSION_EVENTS=1',
      ]

    end
  end
  patch_firebase_crashlytics_status_bar_orientation(installer)
