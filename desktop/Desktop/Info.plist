<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>Nooto Beta</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIconFile</key>
    <string>OmiIcon</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <key>LSUIElement</key>
    <false/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
    <key>NSScreenCaptureUsageDescription</key>
    <string>Nooto needs screen recording permission to monitor your focus and detect distractions.</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>Nooto needs permission to detect which application is currently active.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Nooto needs microphone access to transcribe your conversations in real-time.</string>
    <key>NSAudioCaptureUsageDescription</key>
    <string>Nooto needs permission to capture system audio for transcription of calls and meetings.</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Nooto needs Bluetooth access to connect to your Omi wearable device for audio capture and transcription.</string>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>Nooto Auth Callback</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>nooto-desktop</string>
            </array>
        </dict>
    </array>
    <!-- Sparkle Auto-Update Configuration (disabled for Nooto — no feed yet) -->
    <!--
    <key>SUFeedURL</key>
    <string></string>
    -->
    <key>SUEnableAutomaticChecks</key>
    <false/>
    <key>SUAutomaticallyUpdate</key>
    <false/>
</dict>
</plist>
