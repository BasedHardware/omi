{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omi Desktop",
  "version": "1.0.0",
  "identifier": "com.omi.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:tauri:frontend",
    "devUrl": "http://127.0.0.1:5179",
    "beforeBuildCommand": "bun run build:tauri:frontend",
    "frontendDist": "../dist-tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Omi",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["../resources/icon.png"],
    "targets": ["appimage", "deb", "nsis", "rpm", "msi"]
  }
}
