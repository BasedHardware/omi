{
  "name": "omi-windows",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "Based Hardware",
  "homepage": "https://github.com/BasedHardware/omi",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-worktree.ps1",
    "dev:instance": "node scripts/print-instance.mjs --human",
    "seed:auth": "node scripts/seed-auth.mjs",
    "build": "node scripts/ensure-env.mjs && npm run typecheck && electron-vite build && node scripts/bundle-pimono-extension.mjs",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3",
    "build:ocr-helper": "powershell -ExecutionPolicy Bypass -File scripts/build-ocr-helper.ps1",
    "build:audio-helper": "powershell -ExecutionPolicy Bypass -File scripts/build-audio-helper.ps1",
    "build:automation-helper": "powershell -ExecutionPolicy Bypass -File scripts/build-automation-helper.ps1",
    "check:agent-deps": "node scripts/check-agent-deps.mjs",
    "gen:pimono-unpack": "node scripts/gen-pimono-unpack.mjs",
    "verify:pimono-unpack": "node scripts/verify-pimono-unpack.mjs",
    "verify:pimono-spawn": "node scripts/verify-pimono-packaged-spawn.mjs",
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3 && node scripts/ensure-ocr-helper.mjs && node scripts/ensure-audio-helper.mjs && node scripts/ensure-automation-helper.mjs && node scripts/copy-vad-assets.mjs && node scripts/check-agent-deps.mjs && node scripts/verify-pimono-unpack.mjs",
    "vad:assets": "node scripts/copy-vad-assets.mjs",
    "build:unpack": "npm run build && electron-builder --dir --config electron-builder.config.mjs",
    "build:win": "npm run build && electron-builder --win --x64 --config electron-builder.config.mjs",
    "build:mac": "electron-vite build && node scripts/bundle-pimono-extension.mjs && electron-builder --mac --config electron-builder.config.mjs",
    "build:linux": "electron-vite build && node scripts/bundle-pimono-extension.mjs && electron-builder --linux --config electron-builder.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "fixtures:audio": "node scripts/gen-audio-fixtures.mjs",
    "gen:tray-icons": "node scripts/gen-tray-icons.mjs",
    "gen:app-icon": "node scripts/gen-app-icon.mjs",
    "test:e2e:ptt": "node scripts/run-live-e2e.mjs src/main/ipc/pttTranscribe.e2e.test.ts",
    "test:e2e:agent": "node scripts/run-agent-e2e.mjs src/main/codingAgent/acp.e2e.test.ts",
    "test:e2e:conv-sync": "node scripts/run-live-e2e.mjs src/renderer/src/lib/sync/convSync.e2e.test.ts",
    "test:e2e:voice-smoke": "node scripts/run-voice-smoke.mjs",
    "voice:loop-check": "node scripts/run-voice-loop-check.mjs",
    "test:e2e:lifecycle": "node scripts/run-lifecycle-e2e.mjs",
    "test:e2e:rewind-semantic": "node scripts/run-rewind-semantic-e2e.mjs",
    "test:e2e:db-recovery": "node scripts/run-db-recovery-e2e.mjs",
    "test:e2e:rewind-dayscope": "node scripts/run-rewind-dayscope-e2e.mjs",
    "test:e2e:bar": "node scripts/run-bar-e2e.mjs",
    "test:e2e:sidebar": "node scripts/run-sidebar-e2e.mjs",
    "test:e2e:conv-detail": "node scripts/run-conv-detail-e2e.mjs",
    "test:e2e:kg-viewer": "node scripts/run-kg-viewer-e2e.mjs",
    "orb:sheet": "node scripts/orb/contact-sheet.mjs",
    "orb:check": "node scripts/orb/check-invariants.mjs && node scripts/orb/check-motion.mjs && node scripts/orb/check-transitions.mjs",
    "orb:throttle": "node scripts/orb/check-throttle.mjs",
    "verify:oauth-contract": "node scripts/verify-oauth-contract.mjs",
    "verify:oauth-flow": "node scripts/verify-oauth-flow.mjs",
    "vad:playback": "node scripts/run-vad-playback.mjs",
    "soak": "node scripts/run-soak.mjs",
    "soak:verify": "node scripts/soak-verify.mjs",
    "test:e2e:meeting": "node scripts/run-meeting-e2e.mjs",
    "test:e2e:meeting-live": "node scripts/run-meeting-live.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.58.1",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@electron-toolkit/preload": "^3.0.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.8",
    "@electron-toolkit/utils": "^4.0.0",
    "@google/genai": "^2.11.0",
    "@openai/agents-realtime": "^0.13.1",
    "@ricky0123/vad-web": "^0.0.30",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/electron": "^7.15.0",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "electron-updater": "^6.8.9",
    "firebase": "^12.13.0",
    "koffi": "^3.0.2",
    "lucide-react": "^1.16.0",
    "onnxruntime-web": "1.27.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "@mediapipe/tasks-audio": "0.10.35"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.5.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "png2icons": "^2.0.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
