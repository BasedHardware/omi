# Desktop Auth Service — Environment Variables
# Copy to .env and fill in values.
# This is the OAuth broker that handles sign-in for the desktop app.
# It runs separately from the Rust backend on a different port.

# ─── Server ──────────────────────────────────────────────────────────
# Port for the auth service (use your assigned port range, never 8080)
# noa: 10200, ren: 10210, etc. See team port allocation.
PORT=10200

# Callback URL base — must match what Google/Apple see
# For local dev with Cloudflare tunnel, use the tunnel URL
BASE_API_URL=http://localhost:10200

# ─── Firebase ────────────────────────────────────────────────────────
# Path to GCP service account JSON (needs Firebase Auth admin access)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json
# Firebase Web API key (for identity toolkit REST API)
FIREBASE_API_KEY=

# ─── Google OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Apple Sign-In ───────────────────────────────────────────────────
APPLE_CLIENT_ID=me.omi.web
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
