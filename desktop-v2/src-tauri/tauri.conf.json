{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Nooto",
  "version": "0.1.0",
  "identifier": "com.togodynamics.nooto",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Nooto",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "floating",
        "title": "Ask Nooto",
        "url": "index.html?window=floating",
        "width": 500,
        "height": 120,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "center": false
      },
      {
        "label": "whispr",
        "title": "Whispr",
        "url": "index.html?window=whispr",
        "width": 120,
        "height": 80,
        "minWidth": 120,
        "minHeight": 80,
        "maxWidth": 120,
        "maxHeight": 80,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "center": false
      },
      {
        "label": "live-transcript",
        "title": "Live Transcript",
        "url": "index.html?window=live-transcript",
        "width": 420,
        "height": 240,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "center": false
      },
      {
        "label": "companion-buddy",
        "title": "Companion",
        "url": "index.html?window=companion-buddy",
        "width": 96,
        "height": 96,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "center": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecar/pi-agent/dist/nooto-pi-agent"
    ],
    "resources": {
      "sidecar/pi-agent/dist/package.json": "pi-agent/package.json",
      "sidecar/pi-agent/dist/theme": "pi-agent/theme",
      "sidecar/pi-agent/dist/assets": "pi-agent/assets",
      "sidecar/pi-agent/dist/export-html": "pi-agent/export-html",
      "sidecar/pi-agent/dist/photon_rs_bg.wasm": "pi-agent/photon_rs_bg.wasm",
      "sidecar/pi-agent/extensions/nooto-backend": "pi-agent/extensions/nooto-backend",
      "sidecar/pi-agent/extensions/nooto-permissions": "pi-agent/extensions/nooto-permissions"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["nooto"]
      }
    }
  }
}
