# Remote dev GCP + Firebase (cloud dev project, not local emulators)
#
# Use for running the Python backend against the shared dev cloud stack.
# DO NOT use emulator hosts with this stage.
#
# Setup:
#   cp backend/.env.dev.template backend/.env.dev
#   # Fill secrets from GCP Secret Manager (project based-hardware-dev)
#   ln -sf .env.dev backend/.env
#
# Fetch a secret example:
#   gcloud secrets versions access latest --secret=ENCRYPTION_SECRET --project=based-hardware-dev
#
# Never commit backend/.env.dev or backend/.env.

OMI_ENV_STAGE=dev
ENVIRONMENT=development

# --- Firebase / GCP (dev project — non-secret structure) ---
FIREBASE_PROJECT_ID=based-hardware-dev
FIREBASE_AUTH_DOMAIN=based-hardware-dev.firebaseapp.com
GOOGLE_APPLICATION_CREDENTIALS=google-credentials-dev.json
FIRESTORE_DATABASE_ID=(default)

# --- API URLs (dev cloud) ---
BASE_API_URL=https://api.omi.dev
API_BASE_URL=https://api.omi.dev
OPENAI_BASE_URL=https://api.openai.com/v1

# --- LangSmith (non-secret defaults) ---
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=omi-backend-chat
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
OMI_LANGSMITH_AGENTIC_PROMPT_NAME=omi-agentic-system
OMI_LANGSMITH_PROMPT_CACHE_TTL_SECONDS=300

# =============================================================================
# SECRETS — fetch from GCP Secret Manager (based-hardware-dev) or your dev vault
# =============================================================================

FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
ENCRYPTION_SECRET=YOUR_DEV_ENCRYPTION_SECRET
ADMIN_KEY=YOUR_DEV_ADMIN_KEY

