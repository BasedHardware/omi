# Omi Backend — Docker Environment Variables
#
# Copy this file to .env and fill in the required values.
# Only starred (*) variables are required for basic operation.
# The rest have sensible defaults or are for optional features.
#
# Quick start:
#   cp .env.docker .env
#   # Fill in the starred (*) values below
#   docker compose up -d

# ─── GCP / Firebase (* required) ───
# Option A: Service account JSON (paste the full JSON as a single line)
SERVICE_ACCOUNT_JSON=
# Option B: Path to service account key file (mount it into the container)
# GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json

# ─── Firebase Auth (* required for user auth) ───
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# ─── Redis (provided by docker-compose, no changes needed) ───
# REDIS_DB_HOST=redis
# REDIS_DB_PORT=6379
# REDIS_DB_PASSWORD=

# ─── Typesense (provided by docker-compose) ───
# TYPESENSE_HOST=typesense
# TYPESENSE_HOST_PORT=8108
TYPESENSE_API_KEY=omi_typesense_dev_key

# ─── AI / LLM (* at least one required) ───
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# ─── GCS Buckets (optional, for audio/file storage) ───
# BUCKET_SPEECH_PROFILES=
# BUCKET_POSTPROCESSING=
# BUCKET_TEMPORAL_SYNC_LOCAL=
# BUCKET_MEMORIES_RECORDINGS=
# BUCKET_CHAT_FILES=

# ─── Vector DB (optional, for semantic search) ───
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=

# ─── Security ───
ADMIN_KEY=dev_admin_key_change_me
ENCRYPTION_SECRET=omi_dev_encryption_secret_32chars00

# ─── Server ───
BACKEND_PORT=8080
# BASE_API_URL=http://localhost:8080
