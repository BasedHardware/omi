      "type": "stat",
      "targets": [
        { "expr": "sum(rate(nllb_chars_translated_total[$__rate_interval]))", "legendFormat": "chars/s" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
