      "targets": [
        { "expr": "sum(rate(omi_translation_cache_ops_total{result=\"hit\"}[$__rate_interval])) / (sum(rate(omi_translation_cache_ops_total[$__rate_interval])) > 0)", "legendFormat": "hit ratio" }
