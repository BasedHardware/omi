# Local Development Environment Variables
# Copy this file to .env and fill in your dev values

# ============================================
# LOCAL CONFIGURATION
# ============================================

BASE_API_URL=http://localhost:8000
ADMIN_KEY=local-dev-admin-key

# Redis (handled by docker-compose, don't change)
REDIS_DB_HOST=redis
REDIS_DB_PORT=6379
REDIS_DB_PASSWORD=

# ============================================
# REQUIRED - COPY FROM YOUR DEV COOLIFY
# ============================================

# OpenAI
OPENAI_API_KEY=

# Speech-to-Text (at least one required)
DEEPGRAM_API_KEY=
SONIOX_API_KEY=

# Pinecone Vector Database
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Google Cloud Storage Buckets
BUCKET_SPEECH_PROFILES=
BUCKET_BACKUPS=
BUCKET_PLUGINS_LOGOS=

# ============================================
# GOOGLE CLOUD AUTHENTICATION
# ============================================
# Minify your dev credentials: cat google-credentials.json | jq -c
SERVICE_ACCOUNT_JSON=
GOOGLE_CLOUD_PROJECT=

# ============================================
# TYPESENSE
# ============================================
TYPESENSE_HOST=
TYPESENSE_HOST_PORT=
TYPESENSE_API_KEY=

# ============================================
# OPTIONAL SERVICES
# ============================================

HUGGINGFACE_TOKEN=
GITHUB_TOKEN=
WORKFLOW_API_KEY=
HUME_API_KEY=
HUME_CALLBACK_URL=
HOSTED_PUSHER_API_URL=

# Stripe Payments
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Firebase OAuth
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Encryption (use same as your dev instance for data compatibility)
ENCRYPTION_SECRET=

# Perplexity
PERPLEXITY_API_KEY=

# RapidAPI
RAPID_API_HOST=
RAPID_API_KEY=

# Sentry (disabled for local development - set SENTRY_ENABLED=true to enable)
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
