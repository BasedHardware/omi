# Coolify Deployment Environment Variables
# Set these in Coolify dashboard under Environment Variables

# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Your public API URL (set by Coolify domain)
BASE_API_URL=https://your-api-domain.com
ADMIN_KEY=your-secure-admin-key

# Redis (handled by docker-compose, don't change)
REDIS_DB_HOST=redis
REDIS_DB_PORT=6379
REDIS_DB_PASSWORD=optional-redis-password

# ============================================
# API KEYS
# ============================================

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Speech-to-Text (at least one required)
DEEPGRAM_API_KEY=
SONIOX_API_KEY=

# Pinecone Vector Database
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Google Cloud Storage Buckets
BUCKET_SPEECH_PROFILES=gs://your-bucket
BUCKET_BACKUPS=gs://your-bucket
BUCKET_PLUGINS_LOGOS=gs://your-bucket

# ============================================
# GOOGLE CLOUD AUTHENTICATION
# ============================================
# Minify your credentials: cat google-credentials.json | jq -c
SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CLOUD_PROJECT=your-project-id

# ============================================
# TYPESENSE
# ============================================
TYPESENSE_HOST=your-typesense-host
TYPESENSE_HOST_PORT=443
TYPESENSE_API_KEY=

# ============================================
# OPTIONAL SERVICES
# ============================================

HUGGINGFACE_TOKEN=
GITHUB_TOKEN=
WORKFLOW_API_KEY=
HUME_API_KEY=
HUME_CALLBACK_URL=
HOSTED_PUSHER_API_URL=

# Stripe Payments
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Firebase OAuth
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Encryption Secret (IMPORTANT: Keep consistent across environments for data access)
ENCRYPTION_SECRET=omi_your-secure-random-string

# Perplexity
PERPLEXITY_API_KEY=

# RapidAPI
RAPID_API_HOST=
RAPID_API_KEY=

# Sentry Error Tracking (set SENTRY_ENABLED=true to send errors to Sentry)
SENTRY_ENABLED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=1.0
