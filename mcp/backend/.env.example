# =============================================================================
# backend/.env.example
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GITHUB_PAT=your_github_personal_access_token   # required for GitHub worker

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=true

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
LLM_MODEL=moonshotai/kimi-k2-instruct-0905
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# Supabase — shared by BOTH user RAG and club RAG
#
# How to get these:
#   1. Create a project at https://supabase.com
#   2. Go to Project Settings → API
#   3. Copy "Project URL" and "service_role" key (not anon key)
#
# After filling in, run the SQL migration ONCE:
#   Dashboard → SQL Editor → paste contents of backend/scripts/supabase_migration.sql
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>   # preferred (bypasses Row Level Security)
SUPABASE_ANON_KEY=<anon-key>              # fallback if SERVICE_KEY is absent

# -----------------------------------------------------------------------------
# Embedding
# Model: all-MiniLM-L6-v2 (sentence-transformers) — 384 dimensions
# EMBEDDING_DIM must match the VECTOR(384) column in Supabase.
# If you change the model you MUST re-run the migration with the new dimension
# AND re-embed all documents.
# -----------------------------------------------------------------------------
EMBEDDING_DIM=384

# -----------------------------------------------------------------------------
# User RAG — document upload settings
# -----------------------------------------------------------------------------
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# -----------------------------------------------------------------------------
# Club RAG — Google Drive ingestion
#
# 1. Create a Google Cloud service account with Drive read-only scope.
# 2. Download the JSON key → save as backend/credentials/club_service_account.json
# 3. Share the RoboticsClub/ Drive folder with the service account email.
# 4. Paste the root folder ID below (from the Drive URL).
# -----------------------------------------------------------------------------
CLUB_DRIVE_FOLDER_ID=<your-drive-folder-id>

# SUPABASE_URL and SUPABASE_SERVICE_KEY are reused — no extra vars needed.

# -----------------------------------------------------------------------------
# Neo4j Citation Graph (optional — leave blank to disable)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# -----------------------------------------------------------------------------
# Google OAuth (optional — for Google Workspace MCP worker)
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=[http://localhost:3000,http://localhost:5173]

# -----------------------------------------------------------------------------
# MCP servers (enable/disable)
# -----------------------------------------------------------------------------
ENABLE_GMAIL=true
ENABLE_GOOGLE_DRIVE=true
ENABLE_GOOGLE_CALENDAR=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
