# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=deepseek/deepseek-chat-v3-0324

# Redis (handled by docker-compose)
REDIS_URL=redis://redis:6379

# Processing thresholds
CHUNK_THRESHOLD=10
TIME_THRESHOLD_SECONDS=30

# Omi Integration API
OMI_API_URL=https://api.omi.me
OMI_APP_ID=your-app-id-here
OMI_APP_API_KEY=sk_your-api-key-here

# Confidence thresholds (0.0 to 1.0) — higher = stricter filtering
NOTIFY_CONFIDENCE_THRESHOLD=0.8
TASK_CONFIDENCE_THRESHOLD=0.6
MEMORY_CONFIDENCE_THRESHOLD=0.5

# System prompt override (optional — leave unset to use soul/ files + prompts/system.md)
# Only set this if you want to bypass the soul/ directory entirely
# SYSTEM_PROMPT=...
