# Atlassian OAuth 2.0 (3LO) — Jira Cloud
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8080/auth/jira/callback
JIRA_SCOPES=read:jira-work write:jira-work read:jira-user offline_access

# 32-byte random hex; used to HMAC-sign OAuth state tokens.
JIRA_OAUTH_STATE_SECRET=

# Public origin used to build oauth_url returned to chat tools.
BASE_URL=http://localhost:8080

# Token storage (file fallback under DATA_DIR if Redis missing).
REDIS_URL=
DATA_DIR=./data

# OpenAI (proactive transcript intent detection).
OPENAI_API_KEY=

# Proactive flow tuning.
JIRA_AUTOFILE_CONFIDENCE_THRESHOLD=0.85
JIRA_SUGGEST_CONFIDENCE_THRESHOLD=0.6
JIRA_LLM_DAILY_CAP=200

# Nooto backend used for notification callbacks.
OMI_BACKEND_URL=https://nooto-dev.togodynamics.com
OMI_APP_ID=nooto-jira
OMI_APP_SECRET=

LOG_LEVEL=INFO
ENVIRONMENT=dev
