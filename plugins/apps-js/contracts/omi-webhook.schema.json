{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omi.me/schemas/plugin-webhook.conversation.v1.json",
  "title": "Omi Conversation Webhook",
  "type": "object",
  "required": ["created_at", "structured", "transcript_segments"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" },
    "discarded": { "type": "boolean", "default": false },
    "structured": {
      "type": "object",
      "required": ["title", "overview"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "default": "" },
        "overview": { "type": "string", "default": "" },
        "emoji": { "type": "string", "default": "🧠" },
        "category": { "type": "string", "default": "other" },
        "action_items": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": ["description"],
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" },
              "completed": { "type": "boolean", "default": false },
              "created_at": { "type": ["string", "null"], "format": "date-time" },
              "updated_at": { "type": ["string", "null"], "format": "date-time" },
              "due_at": { "type": ["string", "null"], "format": "date-time" },
              "completed_at": { "type": ["string", "null"], "format": "date-time" },
              "conversation_id": { "type": ["string", "null"] }
            }
          }
        },
        "events": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": ["title", "start"],
            "additionalProperties": true,
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string", "default": "" },
              "start": { "type": "string", "format": "date-time" },
              "duration": { "type": "integer", "default": 30 },
              "created": { "type": "boolean", "default": false }
            }
          }
        }
      }
    },
    "transcript_segments": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["text", "is_user", "start", "end"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": ["string", "null"] },
          "text": { "type": "string" },
          "speaker": { "type": ["string", "null"], "default": "SPEAKER_00" },
          "speaker_id": { "type": ["integer", "null"] },
          "is_user": { "type": "boolean" },
          "person_id": { "type": ["string", "null"] },
          "start": { "type": "number" },
          "end": { "type": "number" }
        }
      }
    },
    "photos": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": { "type": ["string", "null"] },
          "base64": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "created_at": { "type": ["string", "null"], "format": "date-time" },
          "discarded": { "type": "boolean", "default": false },
          "data_protection_level": { "type": ["string", "null"] }
        }
      }
    },
    "apps_results": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "app_id": { "type": ["string", "null"] },
          "content": { "type": "string" }
        }
      }
    },
    "plugins_results": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "plugin_id": { "type": ["string", "null"] },
          "content": { "type": "string" }
        }
      }
    }
  }
}
