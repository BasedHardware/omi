# Omi Admin Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.

# Local development only. Set to 1 to enter the dashboard as a non-production
# dev admin without Firebase login. This bypass is hard-disabled when NODE_ENV=production.
NEXT_PUBLIC_DEV_BYPASS_AUTH=0

# Firebase Client SDK (public, safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin SDK (server-side only, never expose)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Omi Backend API
NEXT_PUBLIC_OMI_API_URL=
OMI_API_SECRET_KEY=
NEXT_PUBLIC_PLUGINS_APP_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_UNLIMITED_MONTHLY_PRICE_ID=
STRIPE_UNLIMITED_ANNUAL_PRICE_ID=

# Typesense
TYPESENSE_HOST=
TYPESENSE_API_KEY=

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# PostgreSQL
POSTGRES_URL=

# ShipBob
SHIPBOB_API_KEY=

# Shopify
SHOPIFY_STORE=
SHOPIFY_ACCESS_TOKEN=

# Mixpanel
MIXPANEL_SECRET=
MIXPANEL_API_BASE=

# OpenAI
OPENAI_API_KEY=

# PostHog
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=

# Admin features used only on their respective dashboard pages
ANTHROPIC_API_KEY=
ENCRYPTION_SECRET=
GITHUB_TOKEN=
GOAFFPRO_ACCESS_TOKEN=
TYPESENSE_CONVERSATION_COLLECTION=

# Scheduled cache precomputation and optional analytics cost overrides
CRON_SECRET=
ADMIN_INFRA_OVERHEAD_MONTHLY=
ADMIN_SERVICE_COSTS_JSON=
