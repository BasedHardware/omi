rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInUser(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isServerOwnedV17MemoryPath(collectionId) {
      return collectionId in [
        'memory_items',
        'memory_operations',
        'memory_outbox',
        'memory_control',
        'memory_state',
        'memory_commits',
        'memory_evidence',
        'short_term_lifecycle_transitions'
      ];
    }

    // V17 memory state is server-owned. The backend/Admin SDK performs all
    // reads and writes through IAM and bypasses Firestore client rules. Mobile
    // and web clients must use backend APIs instead of reading internals or
    // writing around the V17 apply gateway, operation journal, head/control
    // documents, evidence records, or outbox.
    match /users/{uid}/{collectionId}/{document=**} {
      allow read, create, update, delete: if false;
    }

    // No new broad client access is introduced by this V17 rules file. Existing
    // non-V17 client-access rules must be added explicitly before deployment if
    // a Firebase project relies on direct client Firestore access.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
